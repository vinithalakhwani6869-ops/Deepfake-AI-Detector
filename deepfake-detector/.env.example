# ════════════════════════════════════════════════════════════════════════════════
# Deepfake Detection API — Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and customize for your deployment.
# Used by docker-compose and local development.
#
# IMPORTANT: Do NOT commit .env to version control (it may contain secrets).
#

# ────────────────────────────────────────────────────────────────────────────────
# API Server Configuration
# ────────────────────────────────────────────────────────────────────────────────

# Host binding (127.0.0.1 = localhost only; 0.0.0.0 = all interfaces)
HOST=127.0.0.1

# Port number (1024-65535; use 8000 for development, 80/443 behind reverse proxy)
PORT=8000

# Environment: development, staging, or production
ENVIRONMENT=development

# ────────────────────────────────────────────────────────────────────────────────
# Model Configuration
# ────────────────────────────────────────────────────────────────────────────────

# Model name (currently supported: efficientnet_b0)
MODEL_NAME=efficientnet_b0

# Path to model weights (relative to project root or absolute path)
# Default location: checkpoints/deepfake_model.pth
# Can be overridden per deployment environment
WEIGHTS_FILE=checkpoints/deepfake_model.pth

# ────────────────────────────────────────────────────────────────────────────────
# Security Configuration
# ────────────────────────────────────────────────────────────────────────────────

# CORS origins (comma-separated; * = allow all, restrict in production)
CORS_ORIGINS=*

# Maximum upload file size (bytes; default: 50 MB)
MAX_UPLOAD_SIZE_MB=50

# ────────────────────────────────────────────────────────────────────────────────
# Logging Configuration
# ────────────────────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text

# Enable file logging (logs written to logs/ directory)
LOG_TO_FILE=true

# Log file rotation: max size before rotating to new file (MB)
LOG_FILE_MAX_SIZE_MB=100

# ────────────────────────────────────────────────────────────────────────────────
# Performance Configuration
# ────────────────────────────────────────────────────────────────────────────────

# Number of inference workers (set to 1 for GPU, > 1 for CPU-only)
WORKERS=1

# Inference timeout (seconds; 0 = no timeout)
INFERENCE_TIMEOUT_SECONDS=30

# ────────────────────────────────────────────────────────────────────────────────
# Debug Configuration (development only)
# ────────────────────────────────────────────────────────────────────────────────

# Enable debug mode (reload on code changes, detailed error messages)
DEBUG=false

# Reload on code change (development only)
RELOAD=false
